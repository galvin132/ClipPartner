# Vercel frontend.
# .env.local should use the local URL; .env.production / Vercel env should use the production URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare Workers API.
# Local worker: http://localhost:8787
# Production worker: https://clip-partner-api.jm-realheart.workers.dev
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787

# Runtime switches
# mock: use preset accounts/data; hybrid: use configured APIs and mock fallbacks; real: require real integrations.
NEXT_PUBLIC_AUTH_MODE=mock
NEXT_PUBLIC_RUNTIME_MODE=mock

# Worker-side mock auth gate. Keep false in production.
# Set ALLOW_MOCK_AUTH=true only in local Worker `.dev.vars` while third-party auth is pending.
ALLOW_MOCK_AUTH=false

# Better Auth runs inside the Worker gateway. Keep the secret server-side only.
# Generate with: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:8787
BETTER_AUTH_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WeChat OAuth
WECHAT_OAUTH_APP_ID=
WECHAT_OAUTH_APP_SECRET=
WECHAT_OAUTH_REDIRECT_URI=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
CLOUDFLARE_QUEUE_NAME=
CLOUDFLARE_WORKER_URL=

# R2 direct browser upload signing for Workers.
# Set these as Wrangler secrets in production instead of exposing them to the frontend.
R2_ACCOUNT_ID=64264c4d87edeb5f9669a3194ffbcc79
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=clip-partner-assets

# Video processing
FFMPEG_WORKER_ENDPOINT=
FFMPEG_WORKER_TOKEN=

# Platform data integrations
DOUYIN_APP_ID=
DOUYIN_APP_SECRET=
WECHAT_CHANNELS_APP_ID=
WECHAT_CHANNELS_APP_SECRET=

# Settlement / finance integrations
PAYMENT_PROVIDER=
PAYMENT_API_ENDPOINT=
PAYMENT_API_KEY=
