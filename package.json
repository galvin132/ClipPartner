{
  "name": "clip-partner",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run build && npm run worker:types && npm audit",
    "smoke": "node scripts/smoke.mjs",
    "persistence:smoke": "node scripts/persistence-smoke.mjs",
    "worker:types": "node ./node_modules/wrangler/bin/wrangler.js types --config workers/api/wrangler.toml",
    "worker:dev": "node ./node_modules/wrangler/bin/wrangler.js dev --config workers/api/wrangler.toml",
    "worker:deploy": "node ./node_modules/wrangler/bin/wrangler.js deploy --config workers/api/wrangler.toml"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "aws4fetch": "^1.0.20",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "typescript": "^6.0.3",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
